# ─── Database ──────────────────────────────────────────────────────────────────
# For local dev / beta (direct Postgres connection):
DATABASE_URL=postgresql://keshav:yourpassword@localhost:5432/keshav_kitchen_dev

# For production with Prisma Accelerate (recommended for prod):
# DATABASE_URL=prisma://accelerate.prisma-data.net/?api_key=...
# DIRECT_DATABASE_URL=postgresql://keshav:yourpassword@db:5432/keshav_kitchen

# ─── PostgreSQL container ──────────────────────────────────────────────────────
POSTGRES_USER=keshav
POSTGRES_PASSWORD=yourpassword

# ─── Next.js app ───────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=3000                     # 3000 for beta, 3002 for production

# Must match the nginx location prefix (no trailing slash):
#   /beta  → beta environment  (docker-compose.dev.yml)
#   /prod  → production        (docker-compose.prod.yml)
NEXT_PUBLIC_BASE_PATH=/beta

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-strong-random-secret

# Must match the deployed URL + basePath:
NEXTAUTH_URL=http://localhost:3000/beta
