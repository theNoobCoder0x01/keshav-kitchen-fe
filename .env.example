# ─── Database ──────────────────────────────────────────────────────────────────
# For Docker beta/dev, use the Compose service hostname:
DATABASE_URL=postgresql://keshav:yourpassword@db:5432/keshav_kitchen_dev

# For Docker production / on-prem, use the production database:
# DATABASE_URL=postgresql://keshav:yourpassword@db:5432/keshav_kitchen

# ─── PostgreSQL container ──────────────────────────────────────────────────────
POSTGRES_USER=keshav
POSTGRES_PASSWORD=yourpassword

# ─── Next.js app ───────────────────────────────────────────────────────────────
NODE_ENV=production           # Docker uses next start
PORT=3000                     # 3000 for beta, 3002 for production

# Must match the nginx location prefix (no trailing slash):
#   /beta-kitchen  → beta environment  (docker-compose.dev.yml)
#   /kitchen       → production        (docker-compose.prod.yml)
NEXT_PUBLIC_BASE_PATH=/beta-kitchen
NEXT_PUBLIC_API_BASE_URL=/beta-kitchen/api

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-strong-random-secret

# Must match the deployed URL + basePath:
NEXTAUTH_URL=http://localhost:3000/beta-kitchen

# ─── Database backups ──────────────────────────────────────────────────────────
# Cron schedule for pg_dump (default: hourly)
BACKUP_SCHEDULE=@hourly
# Number of daily / weekly / monthly backups to keep
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# Puppeteer
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox
