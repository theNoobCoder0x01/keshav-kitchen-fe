{
  "name": "keshav-kitchen-fe",
  "version": "0.1.0",
  "private": true,
  "description": "Keshav Kitchen Frontend",
  "scripts": {
    "dev": "next dev",
    "lint": "eslint .",
    "format": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json}\"",
    "build": "next build",
    "start": "next start",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:migrate:prod": "prisma migrate deploy",
    "setup": "prisma migrate deploy && npm run db:seed",
    "deploy:dev": "APP_ENV_FILE=.env.development docker compose --env-file .env.development -f docker-compose.base.yml -f docker-compose.dev.yml up -d --build",
    "deploy:prod": "APP_ENV_FILE=.env.production docker compose --env-file .env.production -f docker-compose.base.yml -f docker-compose.prod.yml up -d --build",
    "docker:db": "docker compose --env-file .env.development -f docker-compose.base.yml up db pgadmin -d",
    "gen:lockfile": "./scripts/regenerate-lockfile.sh",
    "comment": "// gen:lockfile: To be run directly in macos terminal otherwise it produces differnt lock file that does not work in deployment"
  },
  "dependencies": {
